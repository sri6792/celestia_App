        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.srivi07.celestia_app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "da570ce8-2fe7-4dd7-9748-fd4142862c27"
      }
    }
  }
}
